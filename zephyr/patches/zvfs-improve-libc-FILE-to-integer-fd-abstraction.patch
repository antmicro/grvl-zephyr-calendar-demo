diff --git a/lib/libc/common/source/stdio/fclose.c b/lib/libc/common/source/stdio/fclose.c
new file mode 100644
index 0000000000000..11c8e704f0129
--- /dev/null
+++ b/lib/libc/common/source/stdio/fclose.c
@@ -0,0 +1,25 @@
+/*
+ * Copyright (c) 2025 Antmicro <www.antmicro.com>
+ *
+ * SPDX-License-Identifier: Apache-2.0
+ */
+
+#include <zephyr/sys/fdtable.h>
+#include <unistd.h>
+
+int fclose(FILE *stream)
+{
+	int fd;
+
+	fflush(stream);
+	fd = zvfs_libc_file_get_fd(stream);
+
+	if (!fd) {
+		return EOF;
+	}
+	if (close(fd)) {
+		return EOF;
+	}
+
+	return 0;
+}
